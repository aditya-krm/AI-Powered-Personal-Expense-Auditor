datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TransactionType {
  EXPENSE
  INCOME
  LENT
  BORROWED
  REPAYMENT
}

enum Category {
  FOOD_DINING
  TRANSPORT
  SHOPPING
  BILLS_UTILITIES
  HOUSING
  HEALTH_WELLNESS
  ENTERTAINMENT
  EDUCATION
  GIFTING_DONATION
  BUSINESS_OPERATIONS
  INVESTMENT
  SALARY
  FREELANCE
  BUSINESS_PROFIT
  RETURNS
  REFUNDS
  GIFT_BONUS
  GENERAL
}

enum TransactionStatus {
  PENDING
  CONFIRMED
}

model Transaction {
  id                Int               @id @default(autoincrement())
  type              TransactionType
  amount            Decimal           @db.Decimal(10, 2)
  currency          String            @default("INR") @db.VarChar(3)
  category          Category          @default(GENERAL)
  description       String?           @db.Text
  relatedEntity     String?           @map("related_entity") @db.VarChar(100)
  
  // Logic for Partial Payments/History
  parentId          Int?              @map("parent_id")
  parent            Transaction?      @relation("TransactionHistory", fields: [parentId], references: [id])
  children          Transaction[]     @relation("TransactionHistory")
  
  isSettled         Boolean           @default(false) @map("is_settled")

  // Source tracking — Telegram entries use telegramMessageId, email entries use sourceId
  telegramMessageId String?           @unique @map("telegram_message_id")
  sourceId          String?           @unique @map("source_id")  // Gmail message ID (dedup)

  // Draft Protocol — email auto-detections start as PENDING, manual entries are CONFIRMED
  status            TransactionStatus @default(CONFIRMED) @map("status")

  rawText           String?           @map("raw_text")
  paymentMethod     String?           @map("payment_method") @db.VarChar(50)
  transactionDate   DateTime          @default(now()) @map("transaction_date")
  createdAt         DateTime          @default(now()) @map("created_at")

  @@map("transactions")
  @@index([type, transactionDate])
  @@index([category])
  @@index([status])
}

model FailedTransaction {
  id                Int       @id @default(autoincrement())
  rawText           String    @map("raw_text") @db.Text
  errorReason       String?   @map("error_reason") @db.Text
  telegramMessageId String?   @map("telegram_message_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@map("failed_transactions")
}

model OAuthToken {
  id             Int      @id @default(autoincrement())
  provider       String   @unique @db.VarChar(50)
  accessToken    String   @map("access_token") @db.Text
  refreshToken   String?  @map("refresh_token") @db.Text
  expiryDate     BigInt   @map("expiry_date")
  tokenType      String   @map("token_type") @db.VarChar(50)
  scope          String   @db.Text
  lastHistoryId  String?  @map("last_history_id") @db.VarChar(50) // tracks Gmail history window
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("oauth_tokens")
}

